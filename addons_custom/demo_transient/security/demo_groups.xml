<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Category để nhóm các group lại cho gọn trong Settings -->
    <record id="module_category_demo" model="ir.module.category">
        <field name="name">Demo Transient</field>
        <field name="sequence">100</field>
    </record>

    <!-- Group 1: Nhân viên thường - chỉ xem được record của chính mình -->
    <record id="group_demo_employee" model="res.groups">
        <field name="name">Nhân viên</field>
        <field name="category_id" ref="module_category_demo"/>
    </record>

    <!-- Group 2: Trưởng phòng - xem được toàn bộ phòng ban của mình -->
    <record id="group_demo_manager" model="res.groups">
        <field name="name">Trưởng phòng</field>
        <field name="category_id" ref="module_category_demo"/>
        <!-- Trưởng phòng kế thừa quyền của Nhân viên -->
        <field name="implied_ids" eval="[(4, ref('group_demo_employee'))]"/>
    </record>

    <!-- Group 3: Quản lý - xem được tất cả -->
    <record id="group_demo_admin" model="res.groups">
        <field name="name">Quản lý</field>
        <field name="category_id" ref="module_category_demo"/>
        <!-- Quản lý kế thừa quyền của Trưởng phòng -->
        <field name="implied_ids" eval="[(4, ref('group_demo_manager'))]"/>
    </record>

    <!-- ── Record Rules ─────────────────────────────────────── -->

    <!--
        Nhân viên thường: chỉ xem record của chính mình
        (employee.user_id = current user)
        Dùng domain filter trên model demo.employee
    -->
    <record id="rule_demo_employee_own" model="ir.rule">
        <field name="name">Demo Employee: chỉ xem của mình</field>
        <field name="model_id" ref="model_demo_employee"/>
        <field name="groups" eval="[(4, ref('group_demo_employee'))]"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!--
        Trưởng phòng: xem tất cả nhân viên cùng phòng ban
        user.demo_department là field ta thêm vào res.users
    -->
    <record id="rule_demo_employee_department" model="ir.rule">
        <field name="name">Demo Employee: xem theo phòng ban</field>
        <field name="model_id" ref="model_demo_employee"/>
        <field name="groups" eval="[(4, ref('group_demo_manager'))]"/>
        <field name="domain_force">[('department', '=', user.demo_department)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!--
        Quản lý: xem tất cả - domain rỗng = không giới hạn
    -->
    <record id="rule_demo_employee_admin" model="ir.rule">
        <field name="name">Demo Employee: xem tất cả</field>
        <field name="model_id" ref="model_demo_employee"/>
        <field name="groups" eval="[(4, ref('group_demo_admin'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>
</odoo>
