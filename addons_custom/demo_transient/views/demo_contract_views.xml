<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_demo_contract_list" model="ir.ui.view">
        <field name="name">demo.contract.list</field>
        <field name="model">demo.contract</field>
        <field name="arch" type="xml">
            <list string="Hợp đồng">
                <!--
                    Nhờ _inherits, các field của demo.employee
                    dùng trực tiếp ở đây mà không cần join thủ công
                -->
                <field name="name" string="Tên nhân viên"/>
                <field name="department" string="Phòng ban"/>
                <field name="salary" string="Lương"/>
                <!-- Field riêng của contract -->
                <field name="contract_date"/>
                <field name="contract_type"/>
                <field name="duration_months"/>
            </list>
        </field>
    </record>

    <record id="view_demo_contract_form" model="ir.ui.view">
        <field name="name">demo.contract.form</field>
        <field name="model">demo.contract</field>
        <field name="arch" type="xml">
            <form string="Hợp đồng lao động">
                <sheet>
                    <group string="Thông tin nhân viên (từ demo.employee qua _inherits)">
                        <!--
                            Các field này thực ra nằm trong bảng demo_employee,
                            nhưng truy cập như field của demo.contract nhờ delegation
                        -->
                        <field name="name" string="Tên nhân viên"/>
                        <field name="department"/>
                        <field name="salary"/>
                    </group>
                    <group string="Thông tin hợp đồng (từ bảng demo_contract)">
                        <field name="contract_date"/>
                        <field name="contract_type"/>
                        <field name="duration_months"/>
                    </group>
                    <group string="Link ủy quyền (Many2one tự động tạo)">
                        <!--
                            employee_id được tự động tạo khi save form này.
                            Odoo tạo record demo.employee trước, rồi mới tạo demo.contract
                        -->
                        <field name="employee_id" readonly="1"/>
                    </group>
                    <field name="note" placeholder="Ghi chú..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_demo_contract" model="ir.actions.act_window">
        <field name="name">Hợp đồng Demo</field>
        <field name="res_model">demo.contract</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_demo_contract"
              name="Hợp đồng (Delegation)"
              parent="menu_demo_transient_root"
              action="action_demo_contract"
              sequence="3"/>
</odoo>
