<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List view -->
    <record id="view_demo_employee_list" model="ir.ui.view">
        <field name="name">demo.employee.list</field>
        <field name="model">demo.employee</field>
        <field name="arch" type="xml">
            <list string="Nhân viên">
                <field name="name"/>
                <field name="department"/>
                <field name="salary"/>
                <field name="allowance"/>
                <field name="total_salary"/>
                <field name="salary_level"/>
                <field name="join_date"/>
                <field name="years_of_service"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_demo_employee_form" model="ir.ui.view">
        <field name="name">demo.employee.form</field>
        <field name="model">demo.employee</field>
        <field name="arch" type="xml">
            <form string="Nhân viên">
                <sheet>
                    <group string="Thông tin cá nhân">
                        <field name="name"/>
                        <field name="age"/>
                        <field name="gender"/>
                        <field name="phone"/>
                        <field name="email"/>
                    </group>
                    <group string="Công việc">
                        <field name="department"/>
                        <!-- onchange _onchange_department tự điền allowance khi đổi phòng ban -->
                        <field name="join_date"/>
                        <field name="years_of_service" readonly="1"/>
                        <field name="user_id"/>
                    </group>
                    <group string="Lương">
                        <field name="salary"/>
                        <field name="allowance"/>
                        <!-- compute _compute_total_salary (store=True) -->
                        <field name="total_salary" readonly="1"/>
                        <!-- compute _compute_salary_level (store=True) -->
                        <field name="salary_level" readonly="1"/>
                    </group>
                    <field name="bio" placeholder="Giới thiệu bản thân..."/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action mở wizard từ menu -->
    <record id="action_salary_summary_wizard" model="ir.actions.act_window">
        <field name="name">Tổng hợp lương</field>
        <field name="res_model">salary.summary.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Action danh sách nhân viên -->
    <record id="action_demo_employee" model="ir.actions.act_window">
        <field name="name">Nhân viên Demo</field>
        <field name="res_model">demo.employee</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_demo_transient_root"
              name="Demo Transient"
              sequence="100"/>

    <menuitem id="menu_demo_employee"
              name="Nhân viên"
              parent="menu_demo_transient_root"
              action="action_demo_employee"
              sequence="1"/>

    <menuitem id="menu_salary_wizard"
              name="Tổng hợp lương (Wizard)"
              parent="menu_demo_transient_root"
              action="action_salary_summary_wizard"
              sequence="2"/>
</odoo>
