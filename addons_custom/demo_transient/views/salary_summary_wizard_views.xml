<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_salary_summary_wizard_form" model="ir.ui.view">
        <field name="name">salary.summary.wizard.form</field>
        <field name="model">salary.summary.wizard</field>
        <field name="arch" type="xml">
            <form string="Tổng hợp lương theo phòng ban">
                <sheet>
                    <!-- BƯỚC 1: Nhập điều kiện - chỉ hiện khi state = input -->
                    <group string="Điều kiện lọc" invisible="state == 'result'">
                        <field name="department"/>
                        <field name="min_salary"/>
                    </group>

                    <!-- BƯỚC 2: Kết quả - chỉ hiện khi state = result -->
                    <group string="Kết quả" invisible="state == 'input'">
                        <field name="employee_count"/>
                        <field name="total_salary"/>
                        <field name="average_salary"/>
                    </group>
                    <field name="result_note"
                           invisible="state == 'input'"
                           widget="text"/>

                    <!-- Field kỹ thuật, ẩn -->
                    <field name="state" invisible="1"/>
                </sheet>

                <footer>
                    <!-- Nút tính toán - hiện ở bước input -->
                    <button name="action_compute"
                            string="Tính toán"
                            type="object"
                            class="btn-primary"
                            invisible="state == 'result'"/>

                    <!-- Nút tính lại - hiện ở bước result -->
                    <button name="action_reset"
                            string="Tính lại"
                            type="object"
                            invisible="state == 'input'"/>

                    <button string="Đóng" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
