<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <!-- Nhóm Người đề xuất -->
        <record id="group_purchase_custom_proposer" model="res.groups">
            <field name="name">Người đề xuất mua sắm</field>
            <field name="category_id" ref="base.module_category_inventory_purchase"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Người dùng có thể tạo và gửi duyệt đề xuất mua sắm.</field>
        </record>

        <!-- Nhóm Người phê duyệt / Quản lý -->
        <record id="group_purchase_custom_manager" model="res.groups">
            <field name="name">Quản lý mua sắm</field>
            <field name="category_id" ref="base.module_category_inventory_purchase"/>
            <field name="implied_ids" eval="[(4, ref('purchase_custom.group_purchase_custom_proposer'))]"/>
            <field name="comment">Quản lý có thể phê duyệt hoặc từ chối đề xuất mua sắm.</field>
        </record>
    </data>
</odoo>
