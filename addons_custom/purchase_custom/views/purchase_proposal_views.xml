<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════ -->
    <!-- Approve Wizard View                      -->
    <!-- ═══════════════════════════════════════ -->
    <record id="view_purchase_proposal_approve_wizard_form" model="ir.ui.view">
        <field name="name">purchase.proposal.approve.wizard.form</field>
        <field name="model">purchase.proposal.approve.wizard</field>
        <field name="arch" type="xml">
            <form string="Phê duyệt đề xuất">
                <sheet>
                    <group>
                        <field name="proposal_id" readonly="1"/>
                        <field name="approve_note" nolabel="1"
                               placeholder="Nhập ghi chú khi phê duyệt (không bắt buộc)..."
                               widget="text"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirm_approve" type="object"
                            string="✓ Xác nhận phê duyệt" class="btn-success"/>
                    <button string="Huỷ" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- ═══════════════════════════════════════ -->
    <!-- Reject Wizard View                       -->
    <!-- ═══════════════════════════════════════ -->
    <record id="view_purchase_proposal_reject_wizard_form" model="ir.ui.view">
        <field name="name">purchase.proposal.reject.wizard.form</field>
        <field name="model">purchase.proposal.reject.wizard</field>
        <field name="arch" type="xml">
            <form string="Từ chối đề xuất">
                <sheet>
                    <group>
                        <field name="proposal_id" readonly="1"/>
                        <field name="rejection_reason" nolabel="1"
                               placeholder="Nhập lý do từ chối đề xuất này..."
                               required="1" widget="text"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirm_reject" type="object"
                            string="Xác nhận từ chối" class="btn-danger"/>
                    <button string="Huỷ" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- ═══════════════════════════════════════ -->
    <!-- Proposal Form View                       -->
    <!-- ═══════════════════════════════════════ -->
    <record id="view_purchase_proposal_form" model="ir.ui.view">
        <field name="name">purchase.proposal.form</field>
        <field name="model">purchase.proposal</field>
        <field name="arch" type="xml">
            <form string="Đề xuất mua sắm">
                <header>
                    <!-- Nút gửi duyệt: chỉ hiện khi Nháp và đúng người đề xuất -->
                    <button name="action_submit" type="object"
                            string="Gửi duyệt" class="btn-primary"
                            invisible="not can_submit or state == 'order_created'"/>

                    <!-- Nút phê duyệt: chỉ hiện khi Đang duyệt và là quản lý -->
                    <button name="action_approve" type="object"
                            string="✓ Phê duyệt" class="btn-success"
                            invisible="not can_approve or state == 'order_created'"
                            groups="purchase_custom.group_purchase_custom_manager,base.group_system"/>

                    <!-- Nút từ chối: chỉ hiện khi Đang duyệt và là quản lý -->
                    <button name="action_reject" type="object"
                            string="✗ Từ chối" class="btn-danger"
                            invisible="not can_approve or state == 'order_created'"
                            groups="purchase_custom.group_purchase_custom_manager,base.group_system"/>

                    <!-- Nút tạo đơn hàng: hiện khi Đã duyệt -->
                    <button name="action_create_purchase_order" type="object"
                            string="📦 Tạo đơn hàng" class="btn-primary"
                            invisible="state != 'approved'"
                            groups="purchase_custom.group_purchase_custom_manager,base.group_system"/>

                    <!-- Nút đặt về nháp: từ Đang duyệt hoặc Từ chối (không cho reset từ order_created) -->
                    <button name="action_reset_to_draft" type="object"
                            string="↩ Đặt về Nháp" class="btn-secondary"
                            invisible="state not in ('pending', 'rejected')"/>

                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,pending,approved,order_created"/>
                </header>

                <sheet>
                    <!-- Hidden computed fields -->
                    <field name="can_submit" invisible="1"/>
                    <field name="can_approve" invisible="1"/>

                    <!-- Smart button: đặt hàng liên quan -->
                    <div name="button_box" class="oe_button_box"
                         invisible="order_count == 0">
                        <button name="action_view_purchase_orders" type="object"
                                class="oe_stat_button" icon="fa-shopping-cart">
                            <field name="order_count" widget="statinfo"
                                   string="Đơn đặt hàng"/>
                        </button>
                    </div>

                    <!-- Tên đề xuất nổi bật -->
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Thông tin đề xuất">
                            <field name="proposer_id"
                                   readonly="state != 'draft'"/>
                            <field name="department_id"
                                   context="{'hierarchical_naming': False}"
                                   readonly="state != 'draft'"/>
                            <field name="date_deadline"
                                   readonly="state != 'draft'"/>
                            <field name="vendor_id"
                                   readonly="state not in ('draft', 'pending')"/>
                            <field name="request_date"
                                   readonly="1"
                                   invisible="not request_date"/>
                        </group>
                        <group string="Phê duyệt"
                               invisible="state == 'draft'">
                            <field name="approved_by" readonly="1"
                                   invisible="state not in ('approved',)"/>
                            <field name="approved_date" readonly="1"
                                   invisible="state not in ('approved',)"/>
                            <field name="rejection_reason" readonly="1"
                                   invisible="state != 'rejected'"/>
                        </group>
                    </group>

                    <group string="Nội dung đề xuất" colspan="4">
                        <field name="content" nolabel="1"
                               placeholder="Mô tả chi tiết nhu cầu mua hàng (không bắt buộc)..."
                               readonly="state != 'draft'"/>
                    </group>

                    <notebook>
                        <page string="Sản phẩm/Dịch vụ">
                            <field name="line_ids"
                                   context="{'default_proposal_id': id}"
                                   readonly="state != 'draft'">
                                <list string="Danh sách sản phẩm" editable="bottom"
                                      create="state == 'draft'"
                                      delete="state == 'draft'">
                                    <field name="sequence" widget="handle"/>
                                    <field name="product_id" width="220px"
                                           domain="[('purchase_ok', '=', True)]"/>
                                    <field name="quantity" width="100px"/>
                                    <field name="uom_id" width="100px"
                                           groups="uom.group_uom"/>
                                    <field name="price_unit" widget="monetary"
                                           width="130px" optional="show"/>
                                    <field name="note" width="200px" optional="hide"/>
                                    <field name="currency_id" column_invisible="True"/>
                                </list>
                            </field>

                            <!-- Footer tổng tiền -->
                            <group class="oe_subtotal_footer">
                                <field name="currency_id" invisible="1"/>
                                <field name="total_amount" widget="monetary"
                                       string="Tổng tiền dự kiến"
                                       class="oe_subtotal_footer_separator"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>

                <chatter/>
            </form>
        </field>
    </record>

    <!-- ═══════════════════════════════════════ -->
    <!-- Proposal List View                       -->
    <!-- ═══════════════════════════════════════ -->
    <record id="view_purchase_proposal_list" model="ir.ui.view">
        <field name="name">purchase.proposal.list</field>
        <field name="model">purchase.proposal</field>
        <field name="arch" type="xml">
            <list string="Đề xuất mua sắm"
                  decoration-info="state == 'draft'"
                  decoration-warning="state == 'pending'"
                  decoration-success="state in ('approved', 'order_created')"
                  decoration-danger="state == 'rejected'">
                <field name="name" width="160px"/>
                <field name="proposer_id" width="140px"/>
                <field name="department_id" context="{'hierarchical_naming': False}"/>
                <field name="date_deadline" width="120px"/>
                <field name="request_date" string="Ngày gửi duyệt"
                       optional="show" width="150px"/>
                <field name="line_count" string="Số SP" width="80px"/>
                <field name="total_amount" widget="monetary" width="130px" optional="show"/>
                <field name="state" widget="badge" width="140px"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'pending'"
                       decoration-success="state in ('approved', 'order_created')"
                       decoration-danger="state == 'rejected'"/>
                <field name="currency_id" column_invisible="True"/>
            </list>
        </field>
    </record>

    <!-- ═══════════════════════════════════════ -->
    <!-- Proposal Search View                     -->
    <!-- ═══════════════════════════════════════ -->
    <record id="view_purchase_proposal_search" model="ir.ui.view">
        <field name="name">purchase.proposal.search</field>
        <field name="model">purchase.proposal</field>
        <field name="arch" type="xml">
            <search string="Tìm kiếm đề xuất">
                <field name="name" string="Mã đề xuất"/>
                <field name="proposer_id" string="Người đề xuất"/>
                <field name="department_id" string="Phòng ban"/>
                <field name="content" string="Nội dung"/>

                <!-- Bộ lọc theo trạng thái -->
                <separator/>
                <filter string="Nháp" name="draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter string="Đang duyệt" name="pending"
                        domain="[('state', '=', 'pending')]"/>
                <filter string="Đã duyệt" name="approved"
                        domain="[('state', '=', 'approved')]"/>
                <filter string="Từ chối" name="rejected"
                        domain="[('state', '=', 'rejected')]"/>

                <!-- Bộ lọc theo người dùng -->
                <separator/>
                <filter string="Do tôi đề xuất" name="my_proposals"
                        domain="[('proposer_id.user_id', '=', uid)]"/>
                <filter string="Phòng ban tôi" name="my_department"
                        domain="[('department_id.member_ids', 'in', [uid])]"/>

                <!-- Nhóm theo -->
                <group expand="0" string="Nhóm theo">
                    <filter string="Trạng thái" name="group_state"
                            context="{'group_by': 'state'}"/>
                    <filter string="Người đề xuất" name="group_proposer"
                            context="{'group_by': 'proposer_id'}"/>
                    <filter string="Phòng ban" name="group_department"
                            context="{'group_by': 'department_id'}"/>
                    <filter string="Tháng tạo" name="group_create_date"
                            context="{'group_by': 'create_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ═══════════════════════════════════════ -->
    <!-- Proposal Kanban View                     -->
    <!-- ═══════════════════════════════════════ -->
    <record id="view_purchase_proposal_kanban" model="ir.ui.view">
        <field name="name">purchase.proposal.kanban</field>
        <field name="model">purchase.proposal</field>
        <field name="arch" type="xml">
            <kanban string="Đề xuất mua sắm"
                    default_group_by="state"
                    records_draggable="0">
                <field name="name"/>
                <field name="proposer_id"/>
                <field name="department_id"/>
                <field name="date_deadline"/>
                <field name="total_amount"/>
                <field name="state"/>
                <field name="line_count"/>
                <field name="currency_id"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top mb-0">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                </div>
                                <span class="float-end">
                                    <field name="state" widget="badge"
                                           decoration-info="state == 'draft'"
                                           decoration-warning="state == 'pending'"
                                           decoration-success="state == 'approved'"
                                           decoration-danger="state == 'rejected'"/>
                                </span>
                            </div>
                            <div class="o_kanban_record_body">
                                <div>
                                    <i class="fa fa-user me-1 text-muted"/>
                                    <field name="proposer_id"/>
                                </div>
                                <div>
                                    <i class="fa fa-building me-1 text-muted"/>
                                    <field name="department_id" context="{'hierarchical_naming': False}"/>
                                </div>
                                <div>
                                    <i class="fa fa-calendar me-1 text-muted"/>
                                    Cần hàng: <field name="date_deadline"/>
                                </div>
                                <div class="mt-1">
                                    <span class="badge bg-secondary">
                                        <field name="line_count"/> sản phẩm
                                    </span>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <field name="total_amount" widget="monetary"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ═══════════════════════════════════════ -->
    <!-- Main Action                              -->
    <!-- ═══════════════════════════════════════ -->
    <record id="action_purchase_proposal" model="ir.actions.act_window">
        <field name="name">Đề xuất mua sắm</field>
        <field name="res_model">purchase.proposal</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[]</field>
        <field name="search_view_id" ref="view_purchase_proposal_search"/>
        <field name="context">{'search_default_group_state': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Tạo đề xuất mua sắm đầu tiên!
            </p>
            <p>
                Đề xuất mua sắm giúp bạn quản lý quy trình từ yêu cầu đến phê duyệt.<br/>
                • Tạo đề xuất &amp; thêm danh sách sản phẩm cần mua<br/>
                • Gửi duyệt lên quản lý<br/>
                • Quản lý phê duyệt hoặc từ chối kèm lý do
            </p>
        </field>
    </record>

</odoo>
