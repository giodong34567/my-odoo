<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        SERVER ACTION — ir.actions.server
        QUAN TRỌNG: code trong <field name="code"> chạy trong sandbox bị giới hạn.
        Không được dùng: record.field = value  (STORE_ATTR bị cấm)
        Phải dùng: record.write({'field': value})
    -->

    <!-- Cách 1: viết code trực tiếp, dùng write() thay vì gán trực tiếp -->
    <record id="action_reset_note" model="ir.actions.server">
        <field name="name">Xóa ghi chú</field>
        <field name="model_id" ref="model_student_student"/>
        <field name="binding_model_id" ref="model_student_student"/>
        <field name="state">code</field>
        <field name="code">records.write({'note': False})</field>
    </record>

    <!-- Cách 2: gọi method trên model — cách này linh hoạt hơn -->
    <record id="action_mark_senior" model="ir.actions.server">
        <field name="name">Đánh dấu học sinh lớn tuổi</field>
        <field name="model_id" ref="model_student_student"/>
        <field name="binding_model_id" ref="model_student_student"/>
        <field name="state">code</field>
        <field name="code">records.action_mark_as_senior()</field>
    </record>
</odoo>
