<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_student_list" model="ir.ui.view">
        <field name="name">student.student.list</field>
        <field name="model">student.student</field>
        <field name="arch" type="xml">
            <list string="Học sinh">
                <field name="student_code"/>
                <field name="name"/>
                <field name="age"/>
                <field name="gender"/>
                <field name="email"/>
                <field name="address"/>
                <field name="phone"/>
            </list>
        </field>
    </record>

    <record id="view_student_form" model="ir.ui.view">
        <field name="name">student.student.form</field>
        <field name="model">student.student</field>
        <field name="arch" type="xml">
            <form string="Học sinh">
                <header>
                    <!-- Mỗi button gọi 1 method trả về window action khác nhau -->
                    <button name="action_open_form"
                            string="Mở form (current)"
                            type="object"/>
                    <button name="action_open_in_popup"
                            string="Mở popup (new)"
                            type="object"/>
                    <button name="action_open_list_same_class"
                            string="Cùng năm nhập học"
                            type="object"/>
                    <button name="action_open_new_student"
                            string="Thêm học sinh mới"
                            type="object"
                            class="btn-primary"/>
                </header>
                <sheet>
                    <group string="Thông tin cá nhân">
                        <field name="name"/>
                        <field name="dob"/>
                        <field name="gender"/>
                        <field name="email"/>
                        <field name="phone"/>
                        <field name="address"/>
                    </group>
                    <group string="Thông tin học sinh">
                        <field name="student_code" readonly="1"/>
                        <field name="age"/>
                        <field name="enroll_date"/>
                    </group>
                    <field name="note"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_student" model="ir.actions.act_window">
        <field name="name">Học sinh</field>
        <field name="res_model">student.student</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_student_root" name="Student" sequence="99"/>
    <menuitem id="menu_student" name="Học sinh"
              parent="menu_student_root"
              action="action_student"
              sequence="1"/>
</odoo>
