<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_shopify_sync_log_list" model="ir.ui.view">
        <field name="name">shopify.sync.log.list</field>
        <field name="model">shopify.sync.log</field>
        <field name="arch" type="xml">
            <list create="false" delete="false">
                <field name="timestamp"/>
                <field name="config_id"/>
                <field name="sync_type"/>
                <field name="status"
                       decoration-success="status == 'success'"
                       decoration-warning="status == 'partial'"
                       decoration-danger="status == 'failed'"/>
                <field name="shopify_id"/>
                <field name="message"/>
            </list>
        </field>
    </record>

    <record id="view_shopify_sync_log_search" model="ir.ui.view">
        <field name="name">shopify.sync.log.search</field>
        <field name="model">shopify.sync.log</field>
        <field name="arch" type="xml">
            <search>
                <field name="config_id"/>
                <field name="shopify_id"/>
                <filter name="success" string="Success" domain="[('status','=','success')]"/>
                <filter name="partial" string="Partial"  domain="[('status','=','partial')]"/>
                <filter name="failed"  string="Failed"   domain="[('status','=','failed')]"/>
                <separator/>
                <filter name="product"   string="Product"   domain="[('sync_type','=','product')]"/>
                <filter name="order"     string="Order"     domain="[('sync_type','=','order')]"/>
                <filter name="inventory" string="Inventory" domain="[('sync_type','=','inventory')]"/>
                <group expand="0" string="Group By">
                    <filter name="by_status"    string="Status"    context="{'group_by':'status'}"/>
                    <filter name="by_sync_type" string="Sync Type" context="{'group_by':'sync_type'}"/>
                    <filter name="by_store"     string="Store"     context="{'group_by':'config_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_shopify_sync_log" model="ir.actions.act_window">
        <field name="name">Sync Logs</field>
        <field name="res_model">shopify.sync.log</field>
        <field name="view_mode">list</field>
        <field name="search_view_id" ref="view_shopify_sync_log_search"/>
    </record>
</odoo>
