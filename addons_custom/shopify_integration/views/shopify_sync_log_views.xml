<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_shopify_sync_log_list" model="ir.ui.view">
        <field name="name">shopify.sync.log.list</field>
        <field name="model">shopify.sync.log</field>
        <field name="arch" type="xml">
            <list create="false" delete="false">
                <field name="timestamp" string="Thời gian"/>
                <field name="config_id" string="Cửa hàng"/>
                <field name="sync_type" string="Loại đồng bộ"/>
                <field name="status" string="Trạng thái"
                       decoration-success="status == 'success'"
                       decoration-warning="status == 'partial'"
                       decoration-danger="status == 'failed'"/>
                <field name="shopify_id" string="Shopify ID"/>
                <field name="message" string="Nội dung"/>
            </list>
        </field>
    </record>

    <record id="view_shopify_sync_log_search" model="ir.ui.view">
        <field name="name">shopify.sync.log.search</field>
        <field name="model">shopify.sync.log</field>
        <field name="arch" type="xml">
            <search>
                <field name="config_id" string="Cửa hàng"/>
                <field name="shopify_id" string="Shopify ID"/>
                <filter name="success" string="Thành công"  domain="[('status','=','success')]"/>
                <filter name="partial" string="Một phần"   domain="[('status','=','partial')]"/>
                <filter name="failed"  string="Thất bại"   domain="[('status','=','failed')]"/>
                <separator/>
                <filter name="product"   string="Sản phẩm"   domain="[('sync_type','=','product')]"/>
                <filter name="order"     string="Đơn hàng"   domain="[('sync_type','=','order')]"/>
                <filter name="inventory" string="Tồn kho"    domain="[('sync_type','=','inventory')]"/>
                <group expand="0" string="Nhóm theo">
                    <filter name="by_status"    string="Trạng thái"    context="{'group_by':'status'}"/>
                    <filter name="by_sync_type" string="Loại đồng bộ"  context="{'group_by':'sync_type'}"/>
                    <filter name="by_store"     string="Cửa hàng"      context="{'group_by':'config_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_shopify_sync_log" model="ir.actions.act_window">
        <field name="name">Nhật ký đồng bộ Shopify</field>
        <field name="res_model">shopify.sync.log</field>
        <field name="view_mode">list</field>
        <field name="search_view_id" ref="view_shopify_sync_log_search"/>
    </record>
</odoo>
