<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_shopify_config_form" model="ir.ui.view">
        <field name="name">shopify.config.form</field>
        <field name="model">shopify.config</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_test_connection" type="object"
                            string="Kiểm tra kết nối" class="btn-primary"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Tên cửa hàng"/></h1>
                    </div>
                    <group>
                        <group string="Kết nối">
                            <field name="shop_url" placeholder="https://my-store.myshopify.com"/>
                            <field name="access_token" password="True"/>
                        </group>
                        <group string="Cài đặt">
                            <field name="warehouse_id"/>
                            <field name="last_sync" readonly="1"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_shopify_config_list" model="ir.ui.view">
        <field name="name">shopify.config.list</field>
        <field name="model">shopify.config</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="shop_url"/>
                <field name="warehouse_id"/>
                <field name="last_sync"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="action_shopify_config" model="ir.actions.act_window">
        <field name="name">Cấu hình cửa hàng Shopify</field>
        <field name="res_model">shopify.config</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
